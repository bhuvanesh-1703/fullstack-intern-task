PORT=5100

# Local MongoDB
# MONGO_URI=mongodb://127.0.0.1:27017

# MongoDB Atlas — option A: full URI (Render: paste this as MONGO_URI)
# MONGO_URI=mongodb+srv://YOUR_DB_USER:YOUR_DB_PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# MongoDB Atlas — option B: separate vars (Render: set all three)
# MONGO_USER=your_db_username
# MONGO_PASSWORD=your_db_password
# MONGO_CLUSTER=cluster0.xxxxx.mongodb.net

MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DB_NAME=template_store
JWT_SECRET=your_secure_random_key_here
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password
